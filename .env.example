# Edrak AI Environment Variables

# API Configuration
EDRAK_API_HOST=0.0.0.0
EDRAK_API_PORT=8000
EDRAK_API_WORKERS=4

# Model Configuration
EDRAK_MODEL_PATH=models/edrak_main.pt
EDRAK_USE_GPU=true
EDRAK_GPU_DEVICE=0

# Security
EDRAK_API_KEY=your-secret-api-key-here
EDRAK_ENABLE_AUTH=false

# Logging
EDRAK_LOG_LEVEL=info
EDRAK_LOG_FILE=logs/edrak.log

# Database
EDRAK_DB_URL=sqlite:///data/edrak.db
EDRAK_REDIS_URL=redis://localhost:6379/0

# External Services
OPENAI_API_KEY=your-openai-key-here
HUGGINGFACE_TOKEN=your-hf-token-here

# Development
DEBUG=false
RELOAD=false
